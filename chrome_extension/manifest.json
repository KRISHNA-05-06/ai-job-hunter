{
  "manifest_version": 3,
  "name": "Job Hunter Tracker",
  "version": "1.0",
  "description": "Auto-logs job applications with job description, company, resume version.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.dice.com/*",
    "*://*.joinhandshake.com/*",
    "*://*.jobright.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/jobs*",
        "*://*.glassdoor.com/job*",
        "*://*.glassdoor.com/Job*",
        "*://*.dice.com/job-detail/*",
        "*://*.joinhandshake.com/*",
        "*://*.jobright.ai/jobs/*"
      ],
      "js": ["content.js"],
      "css": ["popup_inline.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": { "48": "icon.png" },
  "background": {
    "service_worker": "background.js"
  }
}
